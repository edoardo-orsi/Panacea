# =============================================================================
# Panacea — Environment Variables
# Copy this file to .env and fill in values for local development.
# In production, inject these via a secrets manager.
# =============================================================================

# --- Infrastructure -----------------------------------------------------------
# TimescaleDB connection string.
# In production each service gets its own user and schema.
DATABASE_URL=postgresql://panacea:panacea@localhost:5432/panacea

# NATS broker URL
NATS_URL=nats://localhost:4222

# --- Observability ------------------------------------------------------------
# Rust log filter. Examples: info | debug | panacea=debug,info
RUST_LOG=info

# OpenTelemetry OTLP endpoint (Jaeger)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# --- Service ports ------------------------------------------------------------
# Used when running services locally outside Docker.
# Inside Docker each service uses PORT=8080 (default).
SCRAPER_PORT=8081
NUTRITION_PORT=8082
SCORING_PORT=8083
EVAL_PORT=8084
RECIPE_PORT=8085
SUPPLEMENT_PORT=8086
TRACKER_PORT=8087
PRICING_PORT=8088
